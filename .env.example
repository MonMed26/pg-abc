# ===== BCA Merchant QRIS Portal =====
BCA_QR_PORTAL_URL=https://qr.klikbca.com/
BCA_QR_USERNAME=your_merchant_email@example.com
BCA_QR_PASSWORD=your_merchant_password

# ===== Server =====
PORT=3000
NODE_ENV=development

# ===== Playwright =====
HEADLESS=true
PW_TIMEOUT=30000
SESSION_FILE=./data/session.json

# ===== API Auth (opsional, kosongkan untuk dev lokal) =====
API_TOKEN=

# ===== Payment Gateway =====
# Static QRIS string yang dicetak/dipasang merchant. Wajib (start dengan "00020101..." dan diakhiri tag CRC 6304XXXX).
BCA_QRIS_STATIC=

# Range kode unik untuk pembeda transaksi (mencegah bentrok). Total amount = baseAmount + uniqueCode.
UNIQUE_CODE_MIN=1
UNIQUE_CODE_MAX=999

# Default expiry untuk payment (detik). Default 15 menit.
PAYMENT_EXPIRES_SECONDS=900

# Database file (SQLite)
DB_PATH=./data/payments.db

# Polling interval (ms). Setiap interval, scraper jalan kalau ada pending payment.
POLL_INTERVAL_MS=15000
# Minimum delay antar poll meskipun banyak permintaan (anti-spam ke portal BCA)
POLL_MIN_INTERVAL_MS=8000

# Timezone yang dipakai BCA (WIB). Jangan diubah kecuali tahu dampaknya.
TIMEZONE=Asia/Jakarta

# ===== Webhook =====
# Default URL webhook callback (bisa di-override per-payment via field `webhookUrl`)
WEBHOOK_URL=
# Secret untuk HMAC SHA256 signature header X-Signature (format: sha256=<hex>)
WEBHOOK_SECRET=
# Maks retry kalau webhook gagal
WEBHOOK_MAX_ATTEMPTS=5
